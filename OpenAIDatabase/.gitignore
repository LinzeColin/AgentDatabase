.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
node_modules/
dist/
*.tsbuildinfo

# Local secrets and raw exports
.env
.env.*
.local_keys/
*.key
*.pem
*.p12
*.pfx
cookies.json
auth.json
session.json
browser-profile/

# Never commit raw unencrypted OpenAI exports.
*.zip
!tests/fixtures/*.zip
*.tar
*.tar.gz
*.tgz
*.bundle
*.part-*
session_history/
data/raw_archives/
data/raw/
data/private_imports/
private_exports/
exports/private/
data/private/

# Local run logs / temporary work
logs/
tmp/
work/

# Large encrypted raw archives are local by default. Commit only if explicitly intended.
data/raw_encrypted/

# Retired writer destination. Current numeric telemetry lives under data/run_logs/token_usage/.
token_usage/current-mac-latest/
data/run_logs/token_usage/*.tmp
data/run_logs/token_usage/**/*.tmp

# Rebuildable indexes and unbounded command output stay local.
data/processed/indexes/*.sqlite*
data/processed/indexes/*.db*
data/run_logs/**/*.log
data/run_logs/**/*stdout*
data/run_logs/**/*stderr*
data/run_logs/**/*transcript*
data/run_logs/**/*.tmp
