      "expression_zh": "时间节省分 = min(100, (automation_count*hours_per_automation_candidate + template_count*hours_per_template_candidate + productization_count*hours_per_productization_candidate + low_value_loop_count*rework_avoidance_hours_per_loop) * score_per_proxy_hour)",
