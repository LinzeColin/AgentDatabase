{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/AgentDatabase/OpenAIDatabase/config/raw_evidence.sidecar.schema.json",
  "title": "OpenAIDatabase Raw Evidence Sidecar V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "classification",
    "source",
    "authorization",
    "hashes",
    "parts",
    "instruction_trust",
    "credential_scan",
    "sanitization_counts",
    "memory_contract"
  ],
  "properties": {
    "schema_version": {"const": "openai_database.raw_evidence_sidecar.v1"},
    "evidence_id": {"type": "string", "pattern": "^raw_[a-f0-9]{32}$"},
    "classification": {"const": "evidence"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_ref", "observed_at", "original_extension"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
        "source_ref": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\\\r\\n]+$"},
        "observed_at": {"type": "string", "format": "date-time"},
        "original_extension": {"enum": [".json", ".jsonl", ".md", ".txt"]}
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorization_id", "owner_id", "decision", "authorized_at", "content_rights_confirmed", "public_repository_allowed"],
      "properties": {
        "authorization_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"},
        "owner_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,127}$"},
        "decision": {"const": "approved_publication"},
        "authorized_at": {"type": "string", "format": "date-time"},
        "content_rights_confirmed": {"const": true},
        "public_repository_allowed": {"const": true}
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_sha256", "sanitized_sha256", "original_bytes", "sanitized_bytes"],
      "properties": {
        "original_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "sanitized_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "original_bytes": {"type": "integer", "minimum": 0},
        "sanitized_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "parts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "path", "bytes", "sha256"],
        "properties": {
          "index": {"type": "integer", "minimum": 1},
          "path": {"type": "string", "pattern": "^data/public_raw/[0-9]{4}-(0[1-9]|1[0-2])/[a-z0-9][a-z0-9-]{0,63}\\.[a-f0-9]{12}\\.part-[0-9]{4}\\.md$"},
          "bytes": {"type": "integer", "minimum": 0, "maximum": 921600},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        }
      }
    },
    "instruction_trust": {"const": "none"},
    "credential_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "hit_count"],
      "properties": {
        "status": {"const": "PASS"},
        "hit_count": {"const": 0}
      }
    },
    "sanitization_counts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 1}
    },
    "memory_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_ref", "allowed_status", "automatic_active_promotion"],
      "properties": {
        "source_type": {"const": "raw_import"},
        "source_ref": {"type": "string", "pattern": "^data/public_raw/[0-9]{4}-(0[1-9]|1[0-2])/[a-z0-9][a-z0-9-]{0,63}\\.[a-f0-9]{12}\\.sidecar\\.json$"},
        "allowed_status": {"const": "candidate"},
        "automatic_active_promotion": {"const": false}
      }
    }
  }
}
