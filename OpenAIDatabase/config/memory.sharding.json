{
  "schema_version": "openai_database.memory_sharding_contract.v1",
  "task_id": "TSK.OpenAIDatabase.PAM1.0002",
  "acceptance_id": "ACC.OpenAIDatabase.PAM1.0002",
  "mode": "ACTIVE_CANONICAL_SHARDING_AFTER_PAM1.0004",
  "input_contract": {
    "format": "jsonl",
    "required_identity_field": "id",
    "precondition": "V2 records must pass config/memory.schema.json and record-hash validation before PAM1.0004 cutover.",
    "canonical_manifest_input": "data/memory/records/manifest.json",
    "legacy_read_only_audit_input": "data/memory/active/active_memory.jsonl",
    "legacy_input_is_not_promoted_to_canonical_truth": true
  },
  "logical_dataset": {
    "directory": "data/memory/records",
    "display_pattern": "records-NNNN.jsonl",
    "shard_name_template": "records-{sequence:04d}.jsonl",
    "sequence_origin": 1,
    "discovery_path": "data/memory/records/manifest.json",
    "single_logical_truth": true,
    "generated_manifest_editable": false,
    "canonical_data_write_owner_task": "TSK.OpenAIDatabase.PAM1.0004"
  },
  "canonicalization": {
    "name": "openai-memory-jsonl-v1",
    "encoding": "utf-8",
    "line_ending": "LF",
    "final_line_ending_required": true,
    "unicode_normalization": "NFC",
    "object_key_order": "unicode_code_point_ascending",
    "json_separators": [",", ":"],
    "array_order": "preserve",
    "record_order": "normalized_id_ascending",
    "floating_point_values_allowed": false,
    "duplicate_json_keys_allowed": false,
    "duplicate_record_ids_allowed": false
  },
  "rotation": {
    "algorithm": "ordered_greedy_v1",
    "rule": "Rotate before a record only when current_shard_bytes + canonical_record_line_bytes > max_shard_bytes; equality is allowed.",
    "single_record_over_limit_action": "FAIL_CLOSED",
    "empty_dataset_shard_count": 0
  },
  "limits": {
    "kib_bytes": 1024,
    "max_shard_kib": 900,
    "max_shard_bytes": 921600,
    "github_contents_documented_full_feature_max_label": "1 MB",
    "github_contents_conservative_comparison_bytes": 1000000,
    "contents_api_conservative_headroom_bytes": 78400,
    "default_discovery_objects": 1,
    "recursive_full_tree_scan_count": 0
  },
  "integrity": {
    "hash_algorithm": "sha256",
    "shard_hash_input": "exact shard bytes including final LF",
    "dataset_hash_input": "exact shard bytes concatenated in manifest sequence",
    "manifest_contains": [
      "ordered shard paths",
      "sequence",
      "record counts",
      "byte counts",
      "shard SHA-256",
      "dataset byte count",
      "dataset SHA-256"
    ],
    "unique_rebuild": "Concatenate every verified shard exactly once in manifest order."
  },
  "request_budget": {
    "default_discovery": "one direct Contents API GET for data/memory/records/manifest.json",
    "default_discovery_object_count": 1,
    "full_dataset_content_get_formula": "1 + shard_count",
    "recursive_tree_scan_required": false
  },
  "github_api_basis": {
    "verified_at": "2026-07-16",
    "contents_api": "https://docs.github.com/en/rest/repos/contents?apiVersion=2026-03-10",
    "contents_observation": "Files at 1 MB or smaller support all endpoint features; directory responses have a 1000-file upper limit. The contract compares against a conservative decimal 1000000 bytes without asserting GitHub's unit convention.",
    "trees_api": "https://docs.github.com/en/rest/git/trees?apiVersion=2026-03-10",
    "trees_observation": "Recursive tree responses are bounded and can be truncated; default discovery therefore uses a direct known object path."
  },
  "security": {
    "record_content_in_plan_output": false,
    "credential_value_echo_allowed": false,
    "absolute_input_paths_allowed": false,
    "path_traversal_allowed": false,
    "symlink_input_allowed": false,
    "corruption_action": "FAIL_CLOSED"
  },
  "cutover": {
    "task_id": "TSK.OpenAIDatabase.PAM1.0004",
    "acceptance_id": "ACC.OpenAIDatabase.PAM1.0004",
    "record_count": 198,
    "shard_count": 1,
    "dataset_bytes": 488877,
    "dataset_sha256": "sha256:fa9edb7191c5751331f52f4103aa1a6709a7a1e22044d6d85e38ed7d771ca927",
    "manifest_sha256": "sha256:019931525ab56adb51847f5920f9d84f168da5ad0ce2d70314aada4bb0e5f39e"
  },
  "current_task_effects": {
    "canonical_record_files_written": 1,
    "canonical_manifest_files_written": 1,
    "legacy_record_files_modified": 0,
    "runtime_writer_changes": 1,
    "runtime_reader_changes": 2,
    "database_additions": 0,
    "service_additions": 0,
    "dependency_additions": 0
  }
}
