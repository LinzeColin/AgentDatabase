{
  "schema_version": "openai_database.resource_routes.v1",
  "purpose": "On-demand resource routing so agents read the smallest sufficient context set before broad search.",
  "default_intent": "startup",
  "default_resource_policy": {
    "load_mode": "summary",
    "max_chars": 6000,
    "freshness_ttl_days": 30,
    "access": "read",
    "reason_required": true
  },
  "routes": [
    {
      "intent": "startup",
      "description": "One-object generated memory handshake; follow indexed paths only when task-relevant.",
      "read_order": [
        "data/memory/agent-memory.json"
      ],
      "conditional_resources": [
        {
          "path": "data/memory/AGENT_MEMORY.md",
          "condition": "Load when the task needs active high-importance hot context after handshake discovery."
        },
        {
          "path": "data/derived/personalization/codex_personalization.md",
          "condition": "Load only for provider-specific Codex personalization beyond canonical active memory."
        },
        {
          "path": "data/derived/profile/CORE_PROFILE.md",
          "condition": "Load only when the task needs stable user profile or taste detail beyond the startup summary."
        }
      ],
      "update_targets": [
        "profile",
        "preference",
        "taste",
        "history",
        "pattern"
      ]
    },
    {
      "intent": "maintenance",
      "description": "Daily automation and maintenance bootstrap path.",
      "read_order": [
        "AGENTS.md",
        "data/derived/personalization/codex_personalization.md"
      ],
      "update_targets": [
        "profile",
        "preference",
        "taste",
        "history",
        "pattern"
      ]
    },
    {
      "intent": "chatgpt_personalization",
      "description": "Compact export for ChatGPT Project / custom instructions style personalization.",
      "read_order": [
        "data/derived/personalization/chatgpt_personalization.md",
        "data/derived/profile/CORE_PROFILE.md",
        "data/memory/active/active_memory.md"
      ],
      "update_targets": [
        "profile",
        "preference",
        "taste"
      ]
    },
    {
      "intent": "codex_personalization",
      "description": "Codex startup and AGENTS.md-oriented personalization.",
      "read_order": [
        "AGENTS.md",
        "data/derived/personalization/codex_personalization.md"
      ],
      "conditional_resources": [
        {
          "path": "data/derived/agent_context/agent_context_pack.json",
          "condition": "Load for architecture maintenance, personalization analysis, or memory audit tasks."
        },
        {
          "path": "config/codex/project.config.toml",
          "condition": "Load only when editing OpenAIDatabase personalization manifests."
        }
      ],
      "update_targets": [
        "profile",
        "preference",
        "history",
        "pattern"
      ]
    },
    {
      "intent": "claude_personalization",
      "description": "Minimal Claude Code startup projection generated from the shared provider-neutral memory bundle.",
      "read_order": [
        "data/derived/personalization/claude_personalization.md"
      ],
      "conditional_resources": [
        {
          "path": "data/derived/agent_context/AGENT_CONTEXT.md",
          "condition": "Load only when the task needs deeper cross-agent context than the compact Claude projection."
        },
        {
          "path": "data/derived/profile/CORE_PROFILE.md",
          "condition": "Load only when the task needs stable profile detail beyond the compact projection."
        },
        {
          "path": "data/derived/project_index/PROJECT_INDEX.md",
          "condition": "Load only for explicit project-continuity intent; project status remains in project governance."
        },
        {
          "path": "data/derived/decision_log/DECISION_LOG.md",
          "condition": "Load only for explicit durable-decision intent."
        }
      ],
      "update_targets": [
        "profile",
        "preference",
        "history",
        "pattern"
      ]
    },
    {
      "intent": "project_history",
      "description": "Project continuity, decisions, and prior work.",
      "read_order": [
        "data/derived/project_index/PROJECT_INDEX.md",
        "data/derived/decision_log/DECISION_LOG.md",
        "data/derived/timeline/TIMELINE.md",
        "data/processed/codex/codex_activity_snapshot.json"
      ],
      "update_targets": [
        "history",
        "pattern",
        "project_context"
      ]
    },
    {
      "intent": "taste_profile",
      "description": "Taste, visual/product preferences, answer style, and recurring quality bar.",
      "read_order": [
        "data/derived/profile/CORE_PROFILE.md",
        "data/derived/codex/codex_agent_recommendations.json",
        "data/memory/active/active_memory.jsonl"
      ],
      "update_targets": [
        "taste",
        "preference",
        "profile"
      ]
    },
    {
      "intent": "evaluation",
      "description": "Verify personalization freshness and architecture completeness.",
      "read_order": [
        "config/evaluation/personalization_harness.json",
        "data/derived/personalization/personalization_export.json",
        "data/run_logs/evaluation_runs/README.md"
      ],
      "update_targets": [
        "history",
        "pattern"
      ]
    }
  ]
}
