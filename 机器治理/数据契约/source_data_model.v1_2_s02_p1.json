{
  "model_id": "memory_atlas_source_data_model_v1_2_s02_p1",
  "task_id": "MA-V12-S02P1",
  "acceptance_id": "ACC-MA-V12-S02P1",
  "status": "phase_s02_p1_source_data_model_completed_pending_s02_p2",
  "purpose": "Define the shared source data model for ChatGPT, Codex and future other agents before creating the S02 P2 source registry.",
  "required_fields": [
    "source_id",
    "source_type",
    "agent_name",
    "raw_root",
    "sync_mode",
    "public_backup_mode",
    "connector_capability"
  ],
  "optional_fields_for_later_registry": [
    "connector_type",
    "transcript_schema",
    "credential_boundary",
    "sync_frequency",
    "derived_outputs"
  ],
  "source_type_enum": [
    "chatgpt",
    "codex",
    "other_agent"
  ],
  "sync_mode_enum": [
    "manual",
    "scheduled",
    "on_demand",
    "dry_run"
  ],
  "public_backup_mode_enum": [
    "plaintext_public"
  ],
  "connector_capability_enum": [
    "browser_readonly",
    "official_export_fallback",
    "local_session_sync",
    "local_file",
    "api",
    "manual_import"
  ],
  "field_contract": {
    "source_id": {
      "type": "string",
      "required": true,
      "rule": "stable_unique_id_for_source_registry"
    },
    "source_type": {
      "type": "enum",
      "required": true,
      "allowed_values": [
        "chatgpt",
        "codex",
        "other_agent"
      ]
    },
    "agent_name": {
      "type": "string",
      "required": true,
      "rule": "human_readable_agent_or_connector_name"
    },
    "raw_root": {
      "type": "repo_relative_path",
      "required": true,
      "rule": "points_to_future_public_raw_root_without_creating_or_modifying_raw_in_s02_p1"
    },
    "sync_mode": {
      "type": "enum",
      "required": true,
      "allowed_values": [
        "manual",
        "scheduled",
        "on_demand",
        "dry_run"
      ]
    },
    "public_backup_mode": {
      "type": "enum",
      "required": true,
      "allowed_values": [
        "plaintext_public"
      ]
    },
    "connector_capability": {
      "type": "array",
      "required": true,
      "allowed_values": [
        "browser_readonly",
        "official_export_fallback",
        "local_session_sync",
        "local_file",
        "api",
        "manual_import"
      ]
    }
  },
  "transcript_boundary": {
    "rule": "transcript_is_not_credential",
    "allowed_content": [
      "conversation_title",
      "conversation_content",
      "message_text",
      "timestamp",
      "speaker_role",
      "metadata",
      "tool_call_summary",
      "attachment_reference"
    ],
    "notes": "Transcript data may be backed up publicly after user authorization, but it must not include account-control credentials."
  },
  "credential_boundary": {
    "rule": "credentials_not_transcript",
    "forbidden_content": [
      "cookies",
      "session_tokens",
      "passwords",
      "api_keys",
      "private_keys",
      "oauth_tokens",
      "browser_credential_store"
    ],
    "validation_action": "fail_closed_before_commit_or_public_backup"
  },
  "source_templates": {
    "chatgpt_template": {
      "source_id": "chatgpt",
      "source_type": "chatgpt",
      "agent_name": "ChatGPT",
      "raw_root": "data/public_raw/chatgpt",
      "sync_mode": "manual",
      "public_backup_mode": "plaintext_public",
      "connector_capability": [
        "browser_readonly",
        "official_export_fallback"
      ]
    },
    "codex_template": {
      "source_id": "codex",
      "source_type": "codex",
      "agent_name": "Codex",
      "raw_root": "data/public_raw/codex",
      "sync_mode": "manual",
      "public_backup_mode": "plaintext_public",
      "connector_capability": [
        "local_session_sync"
      ]
    },
    "future_agent_template": {
      "source_id": "{agent_id}",
      "source_type": "other_agent",
      "agent_name": "{Agent Display Name}",
      "raw_root": "data/public_raw/agents/{agent_id}",
      "sync_mode": "manual",
      "public_backup_mode": "plaintext_public",
      "connector_capability": [
        "local_file",
        "browser_readonly",
        "api",
        "manual_import"
      ]
    }
  },
  "phase_boundary": {
    "does_not_create_source_registry": true,
    "does_not_create_human_sync_page": true,
    "does_not_touch_raw_archive": true,
    "does_not_implement_connector": true,
    "next_phase": "S02 P2 source registry"
  }
}
