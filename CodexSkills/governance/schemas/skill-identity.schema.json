{
  "$id": "urn:linzecolin:agentdatabase:skillops:schema:skill-identity:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "applicability_manifest_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "bundle_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "canonical_name": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "capability_codes": {
      "items": {
        "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/enum_code"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "created_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "input_contract_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "instance_uids": {
      "items": {
        "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/skill_instance_uid"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "lifecycle_status": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/lifecycle_status"
    },
    "output_contract_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "owner_ref": {
      "pattern": "^[a-z][a-z0-9-]{2,63}$",
      "type": "string"
    },
    "protocol_revision": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/protocol_revision"
    },
    "schema_version": {
      "const": "urn:linzecolin:agentdatabase:skillops:schema:skill-identity:v1"
    },
    "skill_identity_uid": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/skill_identity_uid"
    },
    "srv_revision": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/srv_revision"
    },
    "summary": {
      "maxLength": 1000,
      "minLength": 1,
      "type": "string"
    },
    "supersedes_identity_uid": {
      "anyOf": [
        {
          "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/skill_identity_uid"
        },
        {
          "type": "null"
        }
      ]
    },
    "updated_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    }
  },
  "required": [
    "schema_version",
    "protocol_revision",
    "bundle_digest",
    "skill_identity_uid",
    "srv_revision",
    "canonical_name",
    "summary",
    "owner_ref",
    "lifecycle_status",
    "capability_codes",
    "applicability_manifest_digest",
    "input_contract_digest",
    "output_contract_digest",
    "instance_uids",
    "created_at",
    "updated_at",
    "supersedes_identity_uid"
  ],
  "title": "Skill identity",
  "type": "object"
}
