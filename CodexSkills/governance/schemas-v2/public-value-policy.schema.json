{
  "$id": "urn:linzecolin:agentdatabase:skillops:schema:public-value-policy:v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_high_entropy_field_names": {
      "items": {
        "pattern": "^[a-z][a-z0-9_]*$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "approved_digest_value_pattern": {
      "const": "LOWERCASE_SHA256_HEX_64"
    },
    "detectors": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "const": "BLOCK"
          },
          "code": {
            "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/enum_code"
          },
          "kind": {
            "enum": [
              "ABSOLUTE_PATH",
              "EMAIL",
              "HIGH_ENTROPY_FREE_STRING",
              "IP_ADDRESS",
              "PHONE_NUMBER",
              "PRIVATE_KEY",
              "SECRET_TOKEN",
              "URI_CREDENTIAL"
            ]
          }
        },
        "required": [
          "code",
          "kind",
          "action"
        ],
        "type": "object"
      },
      "minItems": 8,
      "type": "array"
    },
    "field_name_allowlist_exact_match_required": {
      "const": true
    },
    "forbidden_field_names": {
      "items": {
        "pattern": "^[a-z][a-z0-9_]*$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "generic_digest_field_substitution_allowed": {
      "const": false
    },
    "low_entropy_sensitive_value_hash_publication_allowed": {
      "const": false
    },
    "max_public_string_length": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/positive_count"
    },
    "policy_id": {
      "const": "urn:linzecolin:agentdatabase:skillops:policy:public-value:v2"
    },
    "protocol_revision": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/protocol_revision"
    },
    "recipient_rule": {
      "additionalProperties": false,
      "properties": {
        "actual_recipient_repo_external": {
          "const": true
        },
        "public_field": {
          "const": "recipient_ref"
        }
      },
      "required": [
        "public_field",
        "actual_recipient_repo_external"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "urn:linzecolin:agentdatabase:skillops:schema:public-value-policy:v2"
    }
  },
  "required": [
    "schema_version",
    "protocol_revision",
    "policy_id",
    "max_public_string_length",
    "forbidden_field_names",
    "allowed_high_entropy_field_names",
    "detectors",
    "recipient_rule",
    "approved_digest_value_pattern",
    "field_name_allowlist_exact_match_required",
    "generic_digest_field_substitution_allowed",
    "low_entropy_sensitive_value_hash_publication_allowed"
  ],
  "title": "Public value policy v2 with exact digest-field allowlisting",
  "type": "object"
}
