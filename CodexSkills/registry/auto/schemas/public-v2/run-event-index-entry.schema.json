{
  "$id": "urn:linzecolin:agentdatabase:skillops:schema:run-event-index-entry:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "BINDING_CORRECTION"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "required": [
          "supersedes_event_uid",
          "supersedes_event_digest"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "RUN_OBSERVED"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "supersedes_event_uid"
              ]
            },
            {
              "required": [
                "supersedes_event_digest"
              ]
            }
          ]
        }
      }
    }
  ],
  "properties": {
    "bundle_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "event_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "event_type": {
      "enum": [
        "BINDING_CORRECTION",
        "RUN_OBSERVED"
      ]
    },
    "event_uid": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/event_uid"
    },
    "first_published_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "index_entry_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "line_number": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/positive_count"
    },
    "occurred_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "part_number": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/positive_count"
    },
    "protocol_revision": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/protocol_revision"
    },
    "schema_version": {
      "const": "urn:linzecolin:agentdatabase:skillops:schema:run-event-index-entry:v1"
    },
    "supersedes_event_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "supersedes_event_uid": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/event_uid"
    }
  },
  "required": [
    "schema_version",
    "protocol_revision",
    "bundle_digest",
    "event_uid",
    "event_digest",
    "event_type",
    "occurred_at",
    "part_number",
    "line_number",
    "first_published_at",
    "index_entry_digest"
  ],
  "title": "Persistent public-safe run event index entry",
  "type": "object"
}
