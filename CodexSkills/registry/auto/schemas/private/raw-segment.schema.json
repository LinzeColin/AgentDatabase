{
  "$id": "urn:linzecolin:agentdatabase:skillops:schema:raw-segment:v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "pattern": "^[a-z][a-z0-9-]{2,63}$",
      "type": "string"
    },
    "adapter_version": {
      "maxLength": 64,
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9]+(?:[.-][a-z0-9]+)*)?$",
      "type": "string"
    },
    "bundle_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "byte_count": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/nonnegative_count"
    },
    "created_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "expires_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "managed_owned": {
      "const": true
    },
    "ownership_marker_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "payload_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "persistence_mode": {
      "enum": [
        "DISABLED",
        "ENABLED_AFTER_CERTIFICATION",
        "TEST_ONLY"
      ]
    },
    "protected_or_legacy": {
      "const": false
    },
    "protocol_revision": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/protocol_revision"
    },
    "record_count": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/nonnegative_count"
    },
    "schema_version": {
      "const": "urn:linzecolin:agentdatabase:skillops:schema:raw-segment:v2"
    },
    "sealed_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "segment_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "segment_uid": {
      "pattern": "^raw_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
      "type": "string"
    },
    "source_generation_uid": {
      "pattern": "^gen_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "protocol_revision",
    "bundle_digest",
    "segment_uid",
    "source_generation_uid",
    "adapter_id",
    "adapter_version",
    "persistence_mode",
    "managed_owned",
    "protected_or_legacy",
    "ownership_marker_digest",
    "payload_digest",
    "record_count",
    "byte_count",
    "created_at",
    "sealed_at",
    "expires_at",
    "segment_digest"
  ],
  "title": "Private managed raw segment metadata",
  "type": "object"
}
