{
  "$id": "urn:linzecolin:agentdatabase:skillops:schema:lock-state:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acquired_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "bundle_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "generation": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/positive_count"
    },
    "heartbeat_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "lease_expires_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "lock_uid": {
      "pattern": "^lck_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
      "type": "string"
    },
    "owner_run_uid": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/run_uid"
    },
    "protocol_revision": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/protocol_revision"
    },
    "released_at": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/utc_z_timestamp"
    },
    "schema_version": {
      "const": "urn:linzecolin:agentdatabase:skillops:schema:lock-state:v1"
    },
    "state_digest": {
      "$ref": "urn:linzecolin:agentdatabase:skillops:schema:common-definitions:v1#/$defs/sha256"
    },
    "status": {
      "enum": [
        "HELD",
        "RELEASED"
      ]
    }
  },
  "required": [
    "schema_version",
    "protocol_revision",
    "bundle_digest",
    "lock_uid",
    "owner_run_uid",
    "generation",
    "status",
    "acquired_at",
    "heartbeat_at",
    "lease_expires_at",
    "state_digest"
  ],
  "title": "Private global publisher lock state",
  "type": "object"
}
