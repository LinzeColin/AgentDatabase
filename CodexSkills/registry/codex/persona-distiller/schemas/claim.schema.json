{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/persona-distiller/claim.schema.json",
  "title": "Atomic Claim",
  "type": "object",
  "required": [
    "claim_id",
    "claim",
    "category",
    "status",
    "source_ids",
    "counter_source_ids",
    "contexts",
    "confidence",
    "created_at"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^clm-[a-f0-9]{12}$"
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "enum": [
        "fact",
        "mental-model",
        "heuristic",
        "value",
        "epistemic",
        "expression",
        "lineage",
        "blind-spot",
        "contradiction",
        "work-method",
        "boundary",
        "soul-hypothesis"
      ]
    },
    "status": {
      "enum": [
        "fact",
        "pattern",
        "hypothesis",
        "unknown",
        "superseded"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counter_source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_clusters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "time_scope": {
      "type": [
        "string",
        "null"
      ]
    },
    "applicability": {
      "type": [
        "string",
        "null"
      ]
    },
    "falsifiers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alternative_explanations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "author_role": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
