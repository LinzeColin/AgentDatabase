{
  "name": "@openaidatabase/memory-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc -b --pretty false",
    "validate:fast": "python3 ../../scripts/memory_atlas_validator_profiles.py --profile fast",
    "validate:sync": "python3 ../../scripts/memory_atlas_validator_profiles.py --profile sync",
    "validate:ui": "python3 ../../scripts/memory_atlas_validator_profiles.py --profile ui",
    "validate:release": "python3 ../../scripts/memory_atlas_validator_profiles.py --profile release"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "d3": "^7.9.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.181.2",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3"
  }
}
