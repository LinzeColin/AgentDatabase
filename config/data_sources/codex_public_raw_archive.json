    "package_format": "tar_gzip",
    "package_member_root": "codex",
    "gzip_compresslevel": 1,
    "gzip_mtime": 0,
    "max_part_bytes": 47185920,
    "part_index_width": 6,
    "manifest_filename": "manifest.json",
