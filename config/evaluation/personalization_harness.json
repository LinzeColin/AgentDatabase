{
  "schema_version": "openai_database.personalization_harness.v1",
  "purpose": "Evaluation harness for the three-layer context source, personalization exports, resource routes, and run logs.",
  "required_files": [
    ".codex/config.toml",
    "config/context_sources/three_layer_context.json",
    "config/context_sources/resource_routes.json",
    "config/codex/config.template.toml",
    "config/codex/project.config.toml",
    "config/evaluation/task_run.schema.json",
    "docs/PERSONAL_CONTEXT_ARCHITECTURE.md",
    "data/derived/personalization/chatgpt_personalization.md",
    "data/derived/personalization/codex_personalization.md",
    "data/derived/personalization/claude_personalization.md",
    "data/derived/personalization/memory_bundle_manifest.json",
    "data/derived/personalization/personalization_export.json"
  ],
  "required_projection_providers": [
    "chatgpt",
    "codex",
    "claude"
  ],
  "required_bundle_fields": [
    "bundle_id",
    "canonical_source_hash",
    "projection_input_hash",
    "generator_version",
    "source_files",
    "source_records",
    "projection_input_files",
    "projection_input_records",
    "projections"
  ],
  "projection_size_limits": {
    "claude": 4096
  },
  "required_export_sections": [
    "Core Profile",
    "Preferences And Taste",
    "History And Patterns",
    "Project And Decision Context",
    "Future Agent Sync Rules"
  ],
  "required_update_targets": [
    "profile",
    "preference",
    "taste",
    "history",
    "pattern"
  ],
  "required_log_categories": [
    "sync_runs",
    "export_runs",
    "evaluation_runs",
    "agent_runs"
  ],
  "forbidden_plaintext_patterns": [
    "sk-",
    "BEGIN PRIVATE KEY",
    "api_key=",
    "password=",
    "Bearer "
  ]
}
